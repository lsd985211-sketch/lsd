{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/seed-system/bootstrap-pack.schema.json",
  "title": "Bootstrap Context Pack",
  "type": "object",
  "required": ["ok", "tool", "generated_at", "workspace", "project_id", "depth", "rules", "architecture"],
  "properties": {
