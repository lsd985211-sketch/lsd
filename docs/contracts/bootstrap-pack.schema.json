    "generated_at": {"type": "string"},
    "workspace": {"type": "string"},
    "project_id": {"type": "string"},
    "task": {"type": "string"},
    "depth": {"type": "string"},
    "rules": {"type": "object"},
    "architecture": {"type": "object"},
    "maintenance": {"type": "object"},
    "capability_index": {"type": "object"},
    "growth_model": {"type": "object"},
    "agent_primitives": {"type": "object"},
    "tool_knowledge": {"type": "object"}
  }
}
